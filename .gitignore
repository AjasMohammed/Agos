reports/
*.db-shm
*.db-wal
*.sock
*.socket
/tools/user/

# Model cache (fastembed downloads)
.fastembed_cache/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment Variables
.env
.env.*
!.env.example
