# AgentOS — Environment Variables Template
# Copy this file to .env and fill in real values before running docker-compose.
#
# IMPORTANT: Never commit .env to version control.

# ── Required ────────────────────────────────────────────────────────────────

# Passphrase used to derive the AES-256-GCM key for the encrypted secrets vault.
# MUST be non-empty. Use a strong, randomly generated passphrase:
#   openssl rand -base64 32
AGENTOS_VAULT_PASSPHRASE=

# ── Optional LLM Endpoint Overrides ─────────────────────────────────────────

# Override the Ollama host (default: http://ollama:11434 in Docker, http://localhost:11434 otherwise)
# AGENTOS_OLLAMA_HOST=http://ollama:11434

# Base URL for a custom / OpenAI-compatible LLM gateway.
# Required if using a provider other than Ollama. No localhost fallback.
# AGENTOS_LLM_URL=https://llm-gateway.internal/v1

# Override the OpenAI base URL (e.g. for a corporate proxy or Azure OpenAI).
# AGENTOS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Logging ──────────────────────────────────────────────────────────────────

# Tracing filter — use 'info' for production, 'debug' for troubleshooting.
# RUST_LOG=agentos=info
