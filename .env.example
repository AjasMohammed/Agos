# AgentOS Docker / Compose environment template.
# Copy to .env before running `docker compose up -d`.
# Never commit your real .env file.

# Optional but recommended:
# If AGENTOS_AUTO_INIT_VAULT=true and this is unset on first boot, AgentOS
# generates a random managed passphrase file inside the persistent volume next
# to the vault database. That convenience mode is easier to operate, but it is
# weaker than supplying the passphrase from a real secret manager.
# AGENTOS_VAULT_PASSPHRASE=

# LLM endpoint overrides.
# AGENTOS_OLLAMA_HOST=http://host.docker.internal:11434
# AGENTOS_LLM_URL=https://llm-gateway.internal/v1
# AGENTOS_OPENAI_BASE_URL=https://api.openai.com/v1

# LLM API keys — stored in the vault, not passed as env vars.
# On first boot, store your key with: agentctl secret store anthropic_api_key sk-ant-...
# Or for OpenAI: agentctl secret store openai_api_key sk-...

# Auto-initialize vault on first boot (recommended for Docker/Kubernetes deployments).
# When enabled and no vault exists, a random passphrase is generated and saved to
# the data volume. Back it up or supply AGENTOS_VAULT_PASSPHRASE from a secret manager.
# AGENTOS_AUTO_INIT_VAULT=true

# OpenTelemetry / tracing.
# AGENTOS_OTEL_ENABLED=true
# AGENTOS_OTEL_ENDPOINT=http://jaeger:4317

# Logging.
RUST_LOG=agentos=info
